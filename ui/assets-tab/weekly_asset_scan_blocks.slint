import { SpinBox, ComboBox, ScrollView } from "std-widgets.slint";

// ══════════════════════════════════════════════════════════════════
//  Design Tokens
// ══════════════════════════════════════════════════════════════════

// Colors
global Theme {
    out property <color> bg-page:         #f0f2f5;
    out property <color> bg-card:         #ffffff;
    out property <color> border-card:     #e2e8f0;
    out property <color> border-input:    #dde3ea;
    out property <color> text-primary:    #1a2332;
    out property <color> text-secondary:  #64748b;
    out property <color> text-hint:       #94a3b8;
    out property <color> text-caption:    #8496a9;
    out property <color> dot-blue:        #3b82f6;
    out property <color> dot-red:         #ef4444;
    out property <color> dropdown-highlight: #2563eb;
}

// ══════════════════════════════════════════════════════════════════
//  Primitives
// ══════════════════════════════════════════════════════════════════

// Card shell – inherits full width from parent, height is content-driven
component Card inherits Rectangle {
    background:           Theme.bg-card;
    border-width:         1px;
    border-color:         Theme.border-card;
    border-radius:        8px;
    drop-shadow-blur:     5px;
    drop-shadow-color:    #00000010;
    drop-shadow-offset-y: 2px;
}

// All-caps muted section caption
component SectionCaption inherits Text {
    font-family:     "Inter";
    font-size:       10px;
    font-weight:     700;
    color:           Theme.text-caption;
    letter-spacing:  0.8px;
}

// Bold field label above an input
component FieldLabel inherits Text {
    font-family:  "Inter";
    font-size:    13px;
    font-weight:  600;
    color:        Theme.text-primary;
}

// Small italic hint line below a field
component HintText inherits Text {
    font-family:  "Inter";
    font-size:    11px;
    font-weight:  400;
    color:        Theme.text-hint;
    wrap:         word-wrap;
}

// Coloured bullet dot for block headers
component BlockDot inherits Rectangle {
    in property <color> dot-color: Theme.dot-blue;
    width:         10px;
    height:        10px;
    border-radius: 5px;
    background:    root.dot-color;
}

// ══════════════════════════════════════════════════════════════════
//  Reusable: SpinBox column  (label + spinbox + optional hint)
// ══════════════════════════════════════════════════════════════════
component SpinColumn inherits VerticalLayout {
    in property <string> label:        "";
    in property <string> hint:         "";          // empty = no hint row
    in property <int>    minimum:      -99999;
    in property <int>    maximum:       99999;
    in property <int>    value:         0;
    in property <float>  step-size:     1;          // informational, SpinBox is int

    out property <int>   current-value <=> spin.value;

    horizontal-stretch: 1;
    spacing: 5px;

    FieldLabel { text: root.label; }

    Rectangle {
        height:        40px;
        background:    Theme.bg-card;
        border-width:  1px;
        border-color:  Theme.border-input;
        border-radius: 6px;
        clip: true;

        spin := SpinBox {
            x: 0; y: 0;
            width:   parent.width;
            height:  parent.height;
            minimum: root.minimum;
            maximum: root.maximum;
            value:   root.value;
        }
    }

    if (root.hint != "") : HintText {
        text: root.hint;
    }
}

// ══════════════════════════════════════════════════════════════════
//  Reusable: ComboBox column  (label + combobox)
// ══════════════════════════════════════════════════════════════════
component ComboColumn inherits VerticalLayout {
    in property <string>        label:   "";
    in property <[string]>      model:   [];
    in property <int>           current-index <=> combo.current-index;
    out property <string>       current-value <=> combo.current-value;

    horizontal-stretch: 1;
    spacing: 5px;

    FieldLabel { text: root.label; }

    Rectangle {
        height:        40px;
        background:    Theme.bg-card;
        border-width:  1px;
        border-color:  Theme.border-input;
        border-radius: 6px;
        clip: true;

        combo := ComboBox {
            x: 0; y: 0;
            width:   parent.width;
            height:  parent.height;
            model:   root.model;
        }
    }
}

// ══════════════════════════════════════════════════════════════════
//  TILE 1 – Weekly Asset Scan Header
// ══════════════════════════════════════════════════════════════════
export component WeeklyAssetScanHeader inherits Card {
    // Width comes from parent; height is content-driven
    VerticalLayout {
        padding-top:    16px;
        padding-bottom: 16px;
        padding-left:   20px;
        padding-right:  20px;
        spacing:        4px;

        HorizontalLayout {
            spacing:   8px;
            alignment: start;

            // Chart/bar icon placeholder (📊 rendered as emoji text)
            
            VerticalLayout {
                alignment: center;
                Image {
                    width: 18px;
                    height: 18px;
                    source: @image-url("../app_icons/Bar_chart_3D.png");
                }
            }

            Text {
                text:               "Weekly Asset Scan (TV Dashboard)";
                font-family:        "Inter";
                font-size:          15px;
                font-weight:        700;
                color:              Theme.text-primary;
                vertical-alignment: center;
            }
        }

        Text {
            text:        "Screenshot-by-Screenshot Workflow | Direkt aus TradingView eintragen | Phase-Score automatisch";
            font-family: "Inter";
            font-size:   12px;
            font-weight: 400;
            color:       Theme.text-secondary;
            wrap:        word-wrap;
        }
    }
}

// ══════════════════════════════════════════════════════════════════
//  TILE 2 – Block 1: Zinsen & Kurve
// ══════════════════════════════════════════════════════════════════
export component Block1ZinsenKurve inherits Card {
    // Exposed output values for the parent / logic layer
    out property <int>    us-2y-yield    <=> col-2y.current-value;
    out property <int>    us-10y-yield   <=> col-10y.current-value;
    out property <int>    curve-spread   <=> col-spread.current-value;
    // TIP/IEF is stored ×100 internally (e.g. 50 = 0.50) because SpinBox is int-only
    out property <int>    tip-ief-ratio  <=> col-ratio.current-value;
    out property <string> tlt-shy-signal <=> col-tlt.current-value;

    VerticalLayout {
        padding-top:    20px;
        padding-bottom: 20px;
        padding-left:   20px;
        padding-right:  20px;
        spacing:        18px;

        // ── Block header ─────────────────────────────────────────
        VerticalLayout {
            spacing: 4px;

            HorizontalLayout {
                spacing:   8px;
                alignment: start;

                BlockDot {
                    dot-color: Theme.dot-blue;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text:               "BLOCK 1: ZINSEN & KURVE (SCREENSHOT 1 & 3)";
                    font-family:        "Inter";
                    font-size:          12px;
                    font-weight:        700;
                    color:              Theme.text-primary;
                    letter-spacing:     0.3px;
                    vertical-alignment: center;
                }
            }

            Text {
                text:        "US02Y, US10Y, 10Y-2Y Spread, TIP, IEF → direkt aus TV ablesen";
                font-family: "Inter";
                font-size:   12px;
                font-weight: 400;
                color:       Theme.text-secondary;
            }
        }

        // ── Row 1: three yield / spread inputs ───────────────────
        HorizontalLayout {
            spacing: 16px;

            col-2y := SpinColumn {
                label:   "US 2Y Yield (%)";
                // Values stored as integer basis points (425 = 4.25 %)
                minimum: 0;
                maximum: 2000;
                value:   0;
                hint:    "";
            }

            col-10y := SpinColumn {
                label:   "US 10Y Yield (%)";
                minimum: 0;
                maximum: 2000;
                value:   0;
                hint:    "";
            }

            col-spread := SpinColumn {
                label:   "10Y-2Y Curve Spread (bp)";
                minimum: -500;
                maximum:  500;
                value:    0;
                hint:    "Phase4: >+50bp | Phase3: 0-50bp | Phase1-2: <0bp";
            }
        }

        // ── Row 2: ratio input + TLT/SHY combobox ────────────────
        HorizontalLayout {
            spacing: 16px;

            col-ratio := SpinColumn {
                label:   "TIP Price / IEF Price (Ratio)";
                // Stored ×100 (50 → 0.50). Display logic maps in parent.
                minimum: 0;
                maximum: 99999;
                value:   50;
                hint:    "Direkt aus TV Ratio-Panel → Real Yields Proxy";
            }

            col-tlt := ComboColumn {
                label:  "TLT vs SHY Performance";
                model: [
                    "Signal",
                    "TLT Rising, SHY Falling (Duration ↑)",
                    "Flat",
                    "TLT Falling, SHY Rising (Duration ↓)"
                ];
                current-index: 0;
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════
//  TILE 3 – Block 2: Credit Spreads  (Header + placeholder)
//  Shown partially in the screenshot; structure mirrors Block 1.
// ══════════════════════════════════════════════════════════════════
export component Block2CreditSpreads inherits Card {
    VerticalLayout {
        padding-top:    20px;
        padding-bottom: 20px;
        padding-left:   20px;
        padding-right:  20px;
        spacing:        4px;

        HorizontalLayout {
            spacing:   8px;
            alignment: start;

            BlockDot {
                dot-color: Theme.dot-red;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text:               "BLOCK 2: CREDIT SPREADS (SCREENSHOT 2 & 3)";
                font-family:        "Inter";
                font-size:          12px;
                font-weight:        700;
                color:              Theme.text-primary;
                letter-spacing:     0.3px;
                vertical-alignment: center;
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════
//  Preview / standalone root  –  remove when embedding in a Tab
// ══════════════════════════════════════════════════════════════════
export component WeeklyAssetScanTab inherits Rectangle {
    background: Theme.bg-page;
    min-width:  700px;

    ScrollView {
        width:  parent.width;
        height: parent.height;

        VerticalLayout {
            width:   parent.width;
            padding: 18px;
            spacing: 12px;
            alignment: start;

            WeeklyAssetScanHeader { }

            Block1ZinsenKurve { }

        }
    }
}
